<!-- 12. TRANSITIONS -->
<section class="ds-transitions-demo" id="transitions">
  <div class="container">
    <h2>Transitions</h2>
    <p>All elements inherit <var>transition-duration</var> and <var>transition-timing-function</var> from the global defaults. By default, <var>transition-property</var> is set to <var>none</var> — opt in by setting it on each element or via a&nbsp;mixin.</p>
    <div class="ds-token-table">
      <table>
        <thead>
          <tr><th>Token / CSS Var</th><th>Value</th></tr>
        </thead>
        <tbody>
          <tr><td>$transition-speed / --transition-speed</td><td>500ms</td></tr>
          <tr><td>$transition-timing / --transition-timing</td><td>ease</td></tr>
        </tbody>
      </table>
    </div>
    <p>Hover over this box to see the default transition:</p>
    <div class="demo-box">Hover me</div>
    <p>Commonly transitioned properties: <var>background-color</var>, <var>transform</var>, <var>opacity</var>, <var>color</var>. Always set <var>transition-property</var> explicitly to enable&nbsp;transitions.</p>
  </div>
</section>

<!-- 13. LINKS -->
<section class="links" id="links">
  <div class="container">
    <h2>Link Styles</h2>
    <p>Four link patterns cover all navigation needs. Each has a corresponding SCSS mixin, CSS class, and EJS helper&nbsp;function.</p>
    <div class="ds-token-table">
      <table>
        <thead>
          <tr><th>Pattern</th><th>SCSS Mixin</th><th>CSS Class</th><th>EJS Helper</th></tr>
        </thead>
        <tbody>
          <tr><td>Inline link</td><td>@include inline-link</td><td>.inline-link</td><td>inlineLink()</td></tr>
          <tr><td>Block link</td><td>@include block-link</td><td>.block-link</td><td>blockLink()</td></tr>
          <tr><td>Button link</td><td>@include button-link</td><td>.button-link</td><td>buttonLink()</td></tr>
          <tr><td>Card link</td><td>@include card-link</td><td>.card-link</td><td>cardLink()</td></tr>
        </tbody>
      </table>
    </div>

    <h3>Inline Link</h3>
    <p>
      This is what an inline <%- inlineLink('inlineLink()', { href: 'javascript: void(0);' }); %> tag looks like
    </p>
    <h3>Block Link</h3>
    <p>
