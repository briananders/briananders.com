<!-- 1. SYSTEM ANATOMY -->
<section class="ds-anatomy" id="anatomy">
  <div class="container">
    <h2>System Anatomy</h2>
    <p>The design system lives in <var>src/styles/system/</var> and is organized into five layers that build on each other.</p>
    <div class="file-tree"><span class="dir">system/</span>
├── <span class="dir">variables/</span>        Design tokens
│   ├── _colors.scss       Google Material palette
│   ├── _defaults.scss     Base unit, transitions, border-radius
│   ├── _fonts.scss        Font families and weights
│   ├── _grid.scss         Grid dimensions
│   ├── _palettes.scss     Semantic color palette
│   ├── _shadows.scss      Box-shadow tokens
│   ├── _spaces.scss       Spacing scale
│   ├── _viewports.scss    Breakpoints
│   └── _z-index.scss      Z-index scale
├── <span class="dir">functions/</span>        SCSS helper functions
│   └── all.scss           css-min(), css-max()
├── <span class="dir">mixins/</span>           Reusable style patterns
│   ├── _animations.scss   Animation mixins
│   ├── _colors.scss       Palette application mixins
│   ├── _elements.scss     Component mixins
│   ├── _grid.scss         Layout mixins
│   ├── _media-queries.scss  Responsive helpers
│   ├── _type.scss         Typography mixins
│   └── _utilities.scss    Box-sizing mixin
├── <span class="dir">styles/</span>           Base element styles
│   ├── _defaults.scss     *, ::selection
│   ├── _elements.scss     HTML element defaults
│   └── _attributes.scss   ARIA attribute styles
└── <span class="dir">classes/</span>          Utility CSS classes
    ├── _display.scss      Display &amp; layout utilities
    ├── _elements.scss     Component classes
    ├── _spacing.scss      Margin &amp; padding utilities
    └── _type.scss         Heading classes</div>
  </div>
</section>

