<section class="links">
  <div class="container">
    <h2>Inline Link</h2>
    <p>
      This is what an inline <%- inlineLink('inlineLink()', { href: 'javascript: void(0);' }); %> tag looks like
    </p>
    <h2>Block Link</h2>
    <p>
      This is what a block link tag looks like.
      <%- blockLink('blockLink()', { href: 'javascript: void(0);' }); %>
    </p>
    <h2>Button Link</h2>
    <p>
      This is what a button link tag looks like.
      <%- buttonLink('buttonLink()', { href: 'javascript: void(0);' }); %>
    </p>
    <h2>Card Link</h2>
    <div class="p">
      <%- cardLink(`<h3>cardLink()</h3><p>This is what a card link tag looks like. This is what a card link tag looks like. This is what a card link tag looks like.</p>`, { href: 'javascript: void(0);' }); %>
    </div>
    <h2>Other</h2>
    <p>
      Button element without any classes. <button>Random button</button>
    </p>
    <p>
      Button element with <var>inline-link</var> class. <button class="inline-link">Inline Link</button>
    </p>
    <p>
      Button element with <var>block-link</var> class. <button class="block-link">Block Link&nbsp;<b>&gt;</b></button>
    </p>
    <p>
      Button element with <var>button-link</var> class. <button class="button-link">Button Link</button>
    </p>
    <p>
