        Source Serif Pro, serif — weight 500
      </li>
      <li class="sans-serif-regular">
        <div class="ds-section-label">@include type--regular-sans-serif</div>
        Roboto, sans-serif — weight 300
      </li>
      <li class="sans-serif-bold">
        <div class="ds-section-label">@include type--bold-sans-serif</div>
        Roboto, sans-serif — weight 500
      </li>
    </ul>
  </div>
</section>

