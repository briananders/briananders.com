      <li>
        <label for="ds-text">Text input</label>
        <input id="ds-text" type="text" placeholder="Text input" />
      </li>
      <li>
        <label for="ds-number">Number input</label>
        <input id="ds-number" type="number" min=1 max=60 step=1 />
      </li>
      <li>
        <label for="ds-range">Range input</label>
        <input id="ds-range" type="range" min=1 max=60 step=1 />
      </li>
      <li>
        <label for="ds-checkbox">Checkbox</label>
        <input id="ds-checkbox" type="checkbox" />
      </li>
      <li>
        <label for="ds-radio">Radio</label>
        <input id="ds-radio" type="radio" />
      </li>
      <li>
        <label for="ds-toggle">Toggle</label>
        <input id="ds-toggle" type="checkbox" class="toggle" />
      </li>
    </ul>
  </div>
</section>

<!-- 15. UTILITY CLASSES -->
<section id="utilities">
  <div class="container">
    <h2>Utility Classes</h2>
    <p>Ready-to-use CSS classes that can be applied directly in HTML without writing custom&nbsp;SCSS.</p>

    <h3>Layout &amp; Display</h3>
    <div class="ds-token-table">
      <table>
        <thead>
          <tr><th>Class</th><th>Property</th></tr>
        </thead>
        <tbody>
          <tr><td>.d-block</td><td>display: block</td></tr>
          <tr><td>.d-flex</td><td>display: flex</td></tr>
          <tr><td>.d-grid</td><td>display: grid</td></tr>
          <tr><td>.d-none</td><td>display: none</td></tr>
          <tr><td>.d-inline-flex</td><td>display: inline-flex</td></tr>
          <tr><td>.flex-wrap</td><td>flex-wrap: wrap</td></tr>
          <tr><td>.justify-center</td><td>justify-content: center</td></tr>
          <tr><td>.justify-between</td><td>justify-content: space-between</td></tr>
          <tr><td>.align-center</td><td>align-items: center</td></tr>
          <tr><td>.gap-{n}</td><td>gap: $s{n} (1,2,3,4,6,8,12)</td></tr>
          <tr><td>.text-center</td><td>text-align: center</td></tr>
          <tr><td>.w-100</td><td>width: 100%</td></tr>
          <tr><td>.relative</td><td>position: relative</td></tr>
          <tr><td>.overflow-hidden</td><td>overflow: hidden</td></tr>
        </tbody>
      </table>
    </div>

    <h3>Spacing</h3>
    <p>Spacing utilities follow the pattern <var>.{property}-{size}</var> where sizes match the spacing&nbsp;scale.</p>
    <div class="ds-token-table">
      <table>
        <thead>
          <tr><th>Pattern</th><th>Example</th><th>Output</th></tr>
        </thead>
        <tbody>
          <tr><td>.mt-{n}</td><td>.mt-4</td><td>margin-top: 24px</td></tr>
          <tr><td>.mb-{n}</td><td>.mb-6</td><td>margin-bottom: 36px</td></tr>
          <tr><td>.ml-{n}</td><td>.ml-2</td><td>margin-left: 12px</td></tr>
          <tr><td>.mr-{n}</td><td>.mr-3</td><td>margin-right: 18px</td></tr>
          <tr><td>.pt-{n}</td><td>.pt-4</td><td>padding-top: 24px</td></tr>
          <tr><td>.pb-{n}</td><td>.pb-6</td><td>padding-bottom: 36px</td></tr>
          <tr><td>.pl-{n}</td><td>.pl-2</td><td>padding-left: 12px</td></tr>
          <tr><td>.pr-{n}</td><td>.pr-3</td><td>padding-right: 18px</td></tr>
          <tr><td>.mx-auto</td><td>.mx-auto</td><td>margin-left/right: auto</td></tr>
        </tbody>
      </table>
    </div>
    <p>Available sizes: 0, 1 (6px), 2 (12px), 3 (18px), 4 (24px), 6 (36px), 8 (48px), 10 (60px), 12&nbsp;(72px).</p>

    <h3>Component Classes</h3>
    <div class="ds-token-table">
      <table>
        <thead>
          <tr><th>Class</th><th>Description</th></tr>
        </thead>
        <tbody>
          <tr><td>.section</td><td>Full-width section with section spacer margin</td></tr>
          <tr><td>.content / .container</td><td>Centered content container with responsive padding</td></tr>
          <tr><td>.paragraph / .p</td><td>Body paragraph with max-width and bottom margin</td></tr>
          <tr><td>.inline-link</td><td>Orange inline link with hover underline</td></tr>
          <tr><td>.block-link</td><td>White block-level link with arrow indicator</td></tr>
          <tr><td>.button / .button-link</td><td>Bordered button with centered text</td></tr>
          <tr><td>.card-link</td><td>Card container with shadow and hover state</td></tr>
          <tr><td>.error</td><td>Red centered error text</td></tr>
          <tr><td>.center</td><td>Center text and justify-content</td></tr>
          <tr><td>.block-center</td><td>Center block with auto margins</td></tr>
          <tr><td>.h1 through .h6</td><td>Apply heading styles to any element</td></tr>
        </tbody>
      </table>
    </div>
  </div>
</section>
