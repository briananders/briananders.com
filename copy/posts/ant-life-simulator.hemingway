{"entityMap":{},"blocks":[{"key":"al01","text":"50 ants (white)","type":"ordered-list-item","depth":0,"inlineStyleRanges":[],"entityRanges":[],"data":{}},{"key":"al02","text":"20 anteaters (green)","type":"ordered-list-item","depth":0,"inlineStyleRanges":[],"entityRanges":[],"data":{}},{"key":"al03","text":"2 adjacent elements of the same type can reproduce. Anteaters, 1 in 8 opportunities. Ants, every other opportunity.","type":"ordered-list-item","depth":0,"inlineStyleRanges":[],"entityRanges":[],"data":{}},{"key":"al04","text":"If an anteater is surrounded by ants, the ants will eat the anteater.","type":"ordered-list-item","depth":0,"inlineStyleRanges":[],"entityRanges":[],"data":{}},{"key":"al05","text":"If an ant is adjacent to an anteater, the anteater will eat it.","type":"ordered-list-item","depth":0,"inlineStyleRanges":[],"entityRanges":[],"data":{}},{"key":"al06","text":"If an anteater goes without eating for 12 turns, it will starve.","type":"ordered-list-item","depth":0,"inlineStyleRanges":[],"entityRanges":[],"data":{}},{"key":"al07","text":"Ants move first","type":"ordered-list-item","depth":0,"inlineStyleRanges":[],"entityRanges":[],"data":{}}]}
