{"entityMap":{},"blocks":[{"key":"bg01","text":"My wife and I grew up in different parts of the United States, and do not agree on where blue ends and green begins. We are going to explore that.","type":"unstyled","depth":0,"inlineStyleRanges":[],"entityRanges":[],"data":{}},{"key":"bg02","text":"Is this more blue or more green?","type":"unstyled","depth":0,"inlineStyleRanges":[],"entityRanges":[],"data":{}}]}
