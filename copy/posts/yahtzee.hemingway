{"entityMap":{"0":{"type":"LINK","mutability":"MUTABLE","data":{"href":"https://en.wikipedia.org/wiki/Yahtzee","rel":"noopener","target":"blank"}},"1":{"type":"LINK","mutability":"MUTABLE","data":{"href":"https://shop.hasbro.com/en-us/product/yahtzee-classic:BA91514C-5056-9047-F5EC-54D5D9B81059","rel":"noopener","target":"blank"}}},"blocks":[{"key":"ya01","text":"This is a knock-off of the phone game Yahtzee. I wanted to see if I could make something similar.","type":"unstyled","depth":0,"inlineStyleRanges":[],"entityRanges":[],"data":{}},{"key":"ya02","text":"Yahtzee is a dice game made by Hasbro. I learned how to play from Wikipedia and the Hasbro site.","type":"unstyled","depth":0,"inlineStyleRanges":[],"entityRanges":[{"offset":37,"length":9,"key":0},{"offset":51,"length":6,"key":1}],"data":{}},{"key":"ya03","text":"How to play","type":"header-two","depth":0,"inlineStyleRanges":[],"entityRanges":[],"data":{}},{"key":"ya04","text":"Roll all five dice.","type":"ordered-list-item","depth":0,"inlineStyleRanges":[],"entityRanges":[],"data":{}},{"key":"ya05","text":"Keep the dice you want to keep.","type":"ordered-list-item","depth":0,"inlineStyleRanges":[],"entityRanges":[],"data":{}},{"key":"ya06","text":"Re-roll the remaining dice.","type":"ordered-list-item","depth":0,"inlineStyleRanges":[],"entityRanges":[],"data":{}},{"key":"ya07","text":"You get up to 3 rolls per turn.","type":"ordered-list-item","depth":0,"inlineStyleRanges":[],"entityRanges":[],"data":{}},{"key":"ya08","text":"After 3 rolls, select a scoring category.","type":"ordered-list-item","depth":0,"inlineStyleRanges":[],"entityRanges":[],"data":{}},{"key":"ya09","text":"Each category can only be used once.","type":"ordered-list-item","depth":0,"inlineStyleRanges":[],"entityRanges":[],"data":{}},{"key":"ya10","text":"There are 13 categories in total.","type":"ordered-list-item","depth":0,"inlineStyleRanges":[],"entityRanges":[],"data":{}},{"key":"ya11","text":"The player with the highest score wins.","type":"ordered-list-item","depth":0,"inlineStyleRanges":[],"entityRanges":[],"data":{}},{"key":"ya12","text":"Some possible combinations are:","type":"unstyled","depth":0,"inlineStyleRanges":[],"entityRanges":[],"data":{}},{"key":"ya13","text":"3-of-a-kind","type":"unordered-list-item","depth":0,"inlineStyleRanges":[],"entityRanges":[],"data":{}},{"key":"ya14","text":"4-of-a-kind","type":"unordered-list-item","depth":0,"inlineStyleRanges":[],"entityRanges":[],"data":{}},{"key":"ya15","text":"Small Straight","type":"unordered-list-item","depth":0,"inlineStyleRanges":[],"entityRanges":[],"data":{}},{"key":"ya16","text":"Large Straight","type":"unordered-list-item","depth":0,"inlineStyleRanges":[],"entityRanges":[],"data":{}},{"key":"ya17","text":"Full House","type":"unordered-list-item","depth":0,"inlineStyleRanges":[],"entityRanges":[],"data":{}},{"key":"ya18","text":"Yahtzee","type":"unordered-list-item","depth":0,"inlineStyleRanges":[],"entityRanges":[],"data":{}},{"key":"ya19","text":"Chance","type":"unordered-list-item","depth":0,"inlineStyleRanges":[],"entityRanges":[],"data":{}},{"key":"ya20","text":"Bonus","type":"unordered-list-item","depth":0,"inlineStyleRanges":[],"entityRanges":[],"data":{}},{"key":"ya21","text":"The upper section scores the sum of the matching dice. The lower section scores based on the combination.","type":"unstyled","depth":0,"inlineStyleRanges":[],"entityRanges":[],"data":{}},{"key":"ya22","text":"If you score at least 63 points in the upper section, you get a 35 point bonus.","type":"unstyled","depth":0,"inlineStyleRanges":[],"entityRanges":[],"data":{}},{"key":"ya23","text":"If you roll a Yahtzee and the Yahtzee category is already filled, you get a 100 point bonus.","type":"unstyled","depth":0,"inlineStyleRanges":[],"entityRanges":[],"data":{}}]}
