{"entityMap":{},"blocks":[{"key":"lc01","text":"If you animate a ball moving from one side of a line to another and back again, and delay the animation just the right amount, you'll end up with an interesting effect.","type":"unstyled","depth":0,"inlineStyleRanges":[],"entityRanges":[],"data":{}},{"key":"lc02","text":"Use the dropdown selector below to choose the number of lines/balls used in the animation.","type":"unstyled","depth":0,"inlineStyleRanges":[],"entityRanges":[],"data":{}}]}
