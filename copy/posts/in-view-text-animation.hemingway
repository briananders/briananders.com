{"entityMap":{"0":{"type":"LINK","mutability":"MUTABLE","data":{"href":"https://developer.mozilla.org/en-US/docs/Web/API/Intersection_Observer_API","rel":"noopener","target":"blank"}}},"blocks":[{"key":"iv01","text":"Instructions","type":"header-two","depth":0,"inlineStyleRanges":[],"entityRanges":[],"data":{}},{"key":"iv02","text":"First, build a basic in-view intersection observer. This will notify the browser when a given element is within the scroll view.","type":"unstyled","depth":0,"inlineStyleRanges":[],"entityRanges":[{"offset":37,"length":22,"key":0}],"data":{}},{"key":"iv03","text":"const inView = (element, callback, options = { rootMargin: '0px 0px 0px 0px' }) => {\n  if (window.IntersectionObserver) {\n    const intersectionObserver = new IntersectionObserver((entries) => {\n      entries.forEach((entry) => {\n        callback(entry.target, entry.isIntersecting);\n      });\n    }, options);\n\n    intersectionObserver.observe(element);\n  } else {\n    callback(element, true);\n  }\n};","type":"code-block","depth":0,"inlineStyleRanges":[],"entityRanges":[],"data":{}},{"key":"iv04","text":"Then, set up some way to change the element's scope when the observer triggers.","type":"unstyled","depth":0,"inlineStyleRanges":[],"entityRanges":[],"data":{}},{"key":"iv05","text":"const inViewOutOfView = (element, isInView) => {\n  element.setAttribute('in-view', isInView);\n};","type":"code-block","depth":0,"inlineStyleRanges":[],"entityRanges":[],"data":{}},{"key":"iv06","text":"Now, attach the observer function to your desired elements. I chose headings and paragraphs, as you can see.","type":"unstyled","depth":0,"inlineStyleRanges":[],"entityRanges":[],"data":{}},{"key":"iv07","text":"const querySelector = 'h1, h2, h3, h4, h5, h6, p';\nArray.from(document.querySelectorAll(querySelector)).forEach((element) => {\n  inView(element, inViewOutOfView, {\n    rootMargin: '-70px 0px -20px 0px',\n  });\n});","type":"code-block","depth":0,"inlineStyleRanges":[],"entityRanges":[],"data":{}},{"key":"iv08","text":"Finally, configure your in-view/out-of-view style changes. And you're good to go.","type":"unstyled","depth":0,"inlineStyleRanges":[],"entityRanges":[],"data":{}},{"key":"iv09","text":"h1, h2, h3, h4, h5, h6, p {\n  transition: opacity 300ms ease, transform 300ms ease;\n\n  &[in-view=false],\n  &:not([in-view]) {\n    transform: translateY(1em) rotateX(-90deg);\n    opacity: 0;\n  }\n}","type":"code-block","depth":0,"inlineStyleRanges":[],"entityRanges":[],"data":{}},{"key":"iv10","text":"The test","type":"header-two","depth":0,"inlineStyleRanges":[],"entityRanges":[],"data":{}},{"key":"iv11","text":"Scroll up and down here, to see the behavior.","type":"unstyled","depth":0,"inlineStyleRanges":[],"entityRanges":[],"data":{}},{"key":"iv12","text":"Conclusion","type":"header-two","depth":0,"inlineStyleRanges":[],"entityRanges":[],"data":{}},{"key":"iv13","text":"Really popular web design trends don't have to be complicated. I hope this was helpful, and maybe you learned a trick or two.","type":"unstyled","depth":0,"inlineStyleRanges":[],"entityRanges":[],"data":{}}]}
