{"entityMap":{"0":{"type":"LINK","mutability":"MUTABLE","data":{"href":"https://en.wikipedia.org/wiki/Podcast","rel":"noopener","target":"blank"}},"1":{"type":"LINK","mutability":"MUTABLE","data":{"href":"https://www.stuffyoushouldknow.com/","rel":"noopener","target":"blank"}},"2":{"type":"LINK","mutability":"MUTABLE","data":{"href":"https://gimletmedia.com/reply-all/","rel":"noopener","target":"blank"}},"3":{"type":"LINK","mutability":"MUTABLE","data":{"href":"https://www.radiolab.org/","rel":"noopener","target":"blank"}},"4":{"type":"LINK","mutability":"MUTABLE","data":{"href":"https://www.npr.org/podcasts/481105292/more-perfect","rel":"noopener","target":"blank"}},"5":{"type":"LINK","mutability":"MUTABLE","data":{"href":"https://freakonomics.com/","rel":"noopener","target":"blank"}},"6":{"type":"LINK","mutability":"MUTABLE","data":{"href":"https://revisionisthistory.com/","rel":"noopener","target":"blank"}},"7":{"type":"LINK","mutability":"MUTABLE","data":{"href":"https://99percentinvisible.org/","rel":"noopener","target":"blank"}},"8":{"type":"LINK","mutability":"MUTABLE","data":{"href":"https://gimletmedia.com/startup/","rel":"noopener","target":"blank"}},"9":{"type":"LINK","mutability":"MUTABLE","data":{"href":"https://gimletmedia.com/crimetown/","rel":"noopener","target":"blank"}}},"blocks":[{"key":"qp01","text":"A podcast is an episodic series of digital audio files which a user can subscribe to so that new episodes are automatically downloaded via web syndication to the user's own local computer, mobile application, or portable media player.","type":"blockquote","depth":0,"inlineStyleRanges":[],"entityRanges":[{"offset":218,"length":13,"key":0}],"data":{}},{"key":"qp02","text":"Podcasts have become a large part of my life. I have always enjoyed audio books, but the downside to audio books is that they are a big time commitment. Podcasts, being episodic and often serial by nature are built as a much more digestible, bite-sized format. Below you'll see some podcasts that I could fairly describe a life changing. No joke. The more you learn about the world, the greater your perspective becomes, and the better your judgement becomes, at least in my opinion. These shows have expanded my perspective and made me a better member of society.","type":"unstyled","depth":0,"inlineStyleRanges":[],"entityRanges":[],"data":{}},{"key":"qp03","text":"Stuff you should know","type":"header-two","depth":0,"inlineStyleRanges":[],"entityRanges":[{"offset":0,"length":21,"key":1}],"data":{}},{"key":"qp04","text":"Reply All","type":"header-two","depth":0,"inlineStyleRanges":[],"entityRanges":[{"offset":0,"length":9,"key":2}],"data":{}},{"key":"qp05","text":"Radio Lab","type":"header-two","depth":0,"inlineStyleRanges":[],"entityRanges":[{"offset":0,"length":9,"key":3}],"data":{}},{"key":"qp06","text":"Radio Lab Presents: More Perfect","type":"header-two","depth":0,"inlineStyleRanges":[],"entityRanges":[{"offset":0,"length":32,"key":4}],"data":{}},{"key":"qp07","text":"Freakonomics","type":"header-two","depth":0,"inlineStyleRanges":[],"entityRanges":[{"offset":0,"length":12,"key":5}],"data":{}},{"key":"qp08","text":"Revisionist History","type":"header-two","depth":0,"inlineStyleRanges":[],"entityRanges":[{"offset":0,"length":19,"key":6}],"data":{}},{"key":"qp09","text":"99% Invisible","type":"header-two","depth":0,"inlineStyleRanges":[],"entityRanges":[{"offset":0,"length":13,"key":7}],"data":{}},{"key":"qp10","text":"Startup","type":"header-two","depth":0,"inlineStyleRanges":[],"entityRanges":[{"offset":0,"length":7,"key":8}],"data":{}},{"key":"qp11","text":"Crimetown","type":"header-two","depth":0,"inlineStyleRanges":[],"entityRanges":[{"offset":0,"length":9,"key":9}],"data":{}}]}
