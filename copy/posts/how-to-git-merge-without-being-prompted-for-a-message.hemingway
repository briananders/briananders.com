{"entityMap":{},"blocks":[{"key":"gm01","text":"What I have learned is that you can set your GIT_EDITOR environment variable in a way that accepts the standard git merge message.","type":"unstyled","depth":0,"inlineStyleRanges":[],"entityRanges":[],"data":{}},{"key":"gm02","text":"In your .bashrc or .zshrc, add this:","type":"unstyled","depth":0,"inlineStyleRanges":[],"entityRanges":[],"data":{}},{"key":"gm03","text":"export GIT_EDITOR='true git commit'","type":"code-block","depth":0,"inlineStyleRanges":[],"entityRanges":[],"data":{}},{"key":"gm04","text":"By exporting this GIT_EDITOR value, you are signalling to the Git prompt: 👍 and commit!","type":"unstyled","depth":0,"inlineStyleRanges":[],"entityRanges":[],"data":{}}]}
